{
  "ten": {
    "predefined_graphs": [
      {
        "name": "deep_trip_graph",
        "auto_start": true,
        "graph": {
          "nodes": [
            {
              "type": "extension",
              "name": "agora_rtc",
              "addon": "agora_rtc",
              "property": {
                "app_id": "${env:AGORA_APP_ID}",
                "channel": "deep_trip_demo",
                "enable_agora_asr": false
              }
            },
            {
              "type": "extension",
              "name": "streamid_adapter",
              "addon": "streamid_adapter"
            },
            {
              "type": "extension",
              "name": "asr",
              "addon": "openai_asr_python",
              "property": {
                "api_key": "${env:OPENAI_API_KEY}"
              }
            },
            {
              "type": "extension",
              "name": "deep_trip",
              "addon": "deep_trip",
              "property": {
                "OPENCLAW_HOST": "${env:OPENCLAW_HOST}",
                "SYSTEM_PROMPT": "${env:SYSTEM_PROMPT}"
              }
            },
            {
              "type": "extension",
              "name": "llm",
              "addon": "openai_llm2_python",
              "property": {
                "api_key": "${env:OPENAI_API_KEY}",
                "model": "gpt-4o",
                "base_url": "https://api.openai.com/v1"
              }
            },
            {
              "type": "extension",
              "name": "tts",
              "addon": "minimax_tts_websocket_python",
              "property": {
                "api_key": "${env:MINIMAX_TTS_API_KEY}",
                "group_id": "${env:MINIMAX_TTS_GROUP_ID}",
                "voice_id": "female-tianmei"
              }
            }
          ],
          "connections": [
            {
              "extension": "agora_rtc",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "streamid_adapter"
                    }
                  ]
                }
              ],
              "cmd": [
                {
                  "name": "on_user_joined",
                  "dest": [
                    {
                      "extension": "deep_trip"
                    }
                  ]
                },
                {
                  "name": "on_user_left",
                  "dest": [
                    {
                      "extension": "deep_trip"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "streamid_adapter",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "asr"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "asr",
              "data": [
                {
                  "name": "asr_result",
                  "dest": [
                    {
                      "extension": "deep_trip"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "deep_trip",
              "data": [
                {
                  "name": "text_data",
                  "dest": [
                    {
                      "extension": "llm"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "llm",
              "data": [
                {
                  "name": "text_data",
                  "dest": [
                    {
                      "extension": "tts"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "tts",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "agora_rtc"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    ],
    "log": {
      "handlers": [
        {
          "matchers": [
            {
              "level": "info"
            }
          ],
          "formatter": {
            "type": "plain",
            "colored": true
          },
          "emitter": {
            "type": "console",
            "config": {
              "stream": "stdout"
            }
          }
        }
      ]
    }
  }
}
