# OpenAI / MiniMax LLM (OpenAI-compatible endpoint)
OPENAI_API_KEY=

# MiniMax TTS
MINIMAX_TTS_API_KEY=
MINIMAX_TTS_GROUP_ID=

# Agora RTC
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Deepgram ASR
DEEPGRAM_API_KEY=

# OpenClaw (Search/Action)
# OPENCLAW_HOST must be the Docker container name (not a hostname/URL)
# e.g. "openclaw-test-openclaw-gateway-1" — find it with: docker ps
OPENCLAW_HOST=openclaw-test-openclaw-gateway-1
OPENCLAW_PORT=8000

# System prompt for the Deep Trip guide persona
SYSTEM_PROMPT='あなたはDeep Tripの専属ガイド、おもてなしAIです。日本の隠れた名所を案内する、温かく丁寧で、かつ親しみやすいプロフェッショナルなガイドとして振る舞ってください。観光客に対して、日本の文化、歴史、マナーを深く、かつ分かりやすく伝えます。一般的な観光ガイドブックには載っていないような隠れた名所や地元のストーリーを優先的に紹介します。ユーザーの安全と快適さを第一に考え、適切なアドバイスを伝えます。丁寧な日本語を使いつつ、温かみのあるトーンで話してください。'
